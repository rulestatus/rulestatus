{
  "name": "rulestatus",
  "version": "1.0.0",
  "description": "ESLint for AI law — executable compliance testing for AI regulations",
  "type": "module",
  "bin": {
    "rulestatus": "./dist/rulestatus.js"
  },
  "scripts": {
    "test": "bun test",
    "lint": "bunx --bun @biomejs/biome check",
    "lint:fix": "bunx --bun @biomejs/biome check --write",
    "build": "bun build ./src/cli/main.ts --outfile ./dist/rulestatus.js --target node --minify && node scripts/postbuild.mjs",
    "build:bun": "bun build ./src/cli/main.ts --compile --minify --outfile ./dist/rulestatus-bin",
    "dev": "bun src/cli/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/rulestatus.js"
  ],
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/pdfkit": "^0.17.6",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "ai",
    "compliance",
    "eu-ai-act",
    "iso-42001",
    "nist-ai-rmf",
    "regulation",
    "testing",
    "ci",
    "lint"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rulestatus/rulestatus",
    "directory": "packages/cli"
  },
  "homepage": "https://rulestatus.com",
  "engines": {
    "node": ">=18.0.0"
  }
}
